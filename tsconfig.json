{
  "compilerOptions": {
    "resolveJsonModule": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "declaration": true,
    "lib": ["es6", "esnext", "es2015"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist",
    "removeComments": true,
    "rootDir": "./",
    "declarationDir": "./types",
    "target": "es6",
    "skipLibCheck": true,
    "baseUrl": "./",
  },
  "exclude": [
    "node_modules",
    "./test/**/*.test.ts",
    "vitest.config.ts",
    "vitest.setup.ts",
  ],
  "include": ["./**/*.ts", "./**/*.json"],
}
